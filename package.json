{
  "name": "ran-ah-lite",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "web:build": "cd apps/web && turbo run build --filter=web",
    "web:dev": "cd apps/web && turbo run dev --filter=web",
    "api:build": "cd apps/api && turbo run build --filter=api",
    "api:dev": "cd apps/api && turbo run dev --filter=api",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types"
  },
  "devDependencies": {
    "prettier": "^3.6.2",
    "turbo": "^2.5.6",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "yarn@4.9.2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "@nestjs/cli": "^11.0.10",
    "next-auth": "^4.24.11"
  }
}
