{
  "name": "Wi-Garn",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "web:dev": "cd apps/web && bun run dev",
    "api:dev": "cd apps/api && bun run dev",
    "web:build": "cd apps/web && bun run build",
    "api:build": "cd apps/api && bun run build",
    "start": "turbo run start",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types"
  },
  "devDependencies": {
    "prettier": "^3.6.2",
    "turbo": "^2.5.6",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.3.11",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "prettier": "^3.6.2",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "turbo": "^2.5.6",
    "typescript": "5.9.2"
  }
}
